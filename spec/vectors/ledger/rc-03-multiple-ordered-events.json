{
  "schema": "ledger-compliance-v1",
  "scenario": "RC-03",
  "name": "Multiple Ordered Events",
  "description": "Events across multiple commits are returned in sequence order",
  "setup": [
    {
      "op": "append",
      "stream_id": "test-stream",
      "experience_id": "exp-test",
      "events": [
        {"sequence": 1, "event_type": "core/TestEvent", "payload": {"n": 1}}
      ]
    },
    {
      "op": "append",
      "stream_id": "test-stream",
      "experience_id": "exp-test",
      "events": [
        {"sequence": 2, "event_type": "core/TestEvent", "payload": {"n": 2}}
      ]
    },
    {
      "op": "append",
      "stream_id": "test-stream",
      "experience_id": "exp-test",
      "events": [
        {"sequence": 3, "event_type": "core/TestEvent", "payload": {"n": 3}}
      ]
    }
  ],
  "checks": [
    {
      "op": "read_stream",
      "stream_id": "test-stream",
      "expect_count": 3,
      "expect_sequences": [1, 2, 3]
    }
  ]
}
