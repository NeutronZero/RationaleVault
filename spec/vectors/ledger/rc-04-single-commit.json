{
  "schema": "ledger-compliance-v1",
  "scenario": "RC-04",
  "name": "Single Commit",
  "description": "A commit with one event is stored and readable",
  "setup": [
    {
      "op": "append",
      "stream_id": "test-stream",
      "experience_id": "exp-test",
      "events": [
        {"sequence": 1, "event_type": "core/TestEvent", "payload": {"data": "single"}}
      ]
    }
  ],
  "checks": [
    {
      "op": "read_stream",
      "stream_id": "test-stream",
      "expect_count": 1,
      "expect_sequences": [1]
    },
    {
      "op": "exists",
      "commit_id": null,
      "expect_exists": true
    }
  ]
}
