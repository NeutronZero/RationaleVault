{
  "name": "rp-03-snapshot-equivalence",
  "description": "Delta replay from a Snapshot produces Understanding identical to Full replay",
  "ledger": {
    "streams": {
      "test-stream": [
        {
          "sequence": 1,
          "global_order": 1,
          "event_type": "decision_recorded",
          "payload": {"value": 1}
        },
        {
          "sequence": 2,
          "global_order": 2,
          "event_type": "decision_recorded",
          "payload": {"value": 2}
        }
      ]
    }
  },
  "replay": {
    "scope": "global",
    "mode": "delta",
    "snapshot": {
      "projection_id": "counter",
      "replay_position": 1,
      "state": {"count": 1, "last_value": 1}
    }
  },
  "expected": {
    "projections": {
      "counter": {"count": 2, "last_value": 2}
    }
  },
  "invariants": ["I-07"]
}
