{
  "name": "rp-09-interrupted-replay",
  "description": "Replay interrupted at global_order 1 then resumed produces Understanding identical to uninterrupted replay through global_order 3",
  "ledger": {
    "streams": {
      "test-stream": [
        {
          "sequence": 1,
          "global_order": 1,
          "event_type": "decision_recorded",
          "payload": {"value": 1}
        },
        {
          "sequence": 2,
          "global_order": 2,
          "event_type": "decision_recorded",
          "payload": {"value": 2}
        },
        {
          "sequence": 3,
          "global_order": 3,
          "event_type": "decision_recorded",
          "payload": {"value": 3}
        }
      ]
    }
  },
  "replay": {"scope": "global"},
  "expected": {
    "projections": {
      "counter": {"count": 3, "last_value": 3}
    }
  },
  "invariants": ["I-01", "I-01a"]
}
