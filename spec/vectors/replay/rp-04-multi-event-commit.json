{
  "name": "rp-04-multi-event-commit",
  "description": "Multiple Events in a single Commit preserve order through Replay",
  "ledger": {
    "streams": {
      "test-stream": [
        {
          "sequence": 1,
          "global_order": 1,
          "event_type": "decision_recorded",
          "payload": {"value": 1}
        },
        {
          "sequence": 2,
          "global_order": 1,
          "event_type": "decision_recorded",
          "payload": {"value": 2}
        },
        {
          "sequence": 3,
          "global_order": 1,
          "event_type": "decision_recorded",
          "payload": {"value": 3}
        }
      ]
    }
  },
  "replay": {"scope": "global"},
  "expected": {
    "projections": {
      "counter": {"count": 3, "last_value": 3}
    }
  },
  "invariants": ["I-01", "I-12"]
}
